{
  "required_status_checks": {
    "strict": true,
    "checks": [
      {
        "context": "CodeQL"
      },
      {
        "context": "ci-smoke / core-smoke"
      },
      {
        "context": "ci-smoke / api-contract-smoke"
      },
      {
        "context": "Web Playwright Tests / playwright-ui"
      },
      {
        "context": "cv-quick-verify / verify"
      },
      {
        "context": "cv-quick-verify / Tapeout Gate Final"
      },
      {
        "context": "security-baseline / pip-audit-runtime"
      },
      {
        "context": "security-baseline / web-determinism-and-audit"
      },
      {
        "context": "tapeout-gate / PIC Tapeout Gate"
      }
    ]
  },
  "enforce_admins": true,
  "required_pull_request_reviews": {
    "dismiss_stale_reviews": true,
    "require_code_owner_reviews": false,
    "required_approving_review_count": 1,
    "require_last_push_approval": false
  },
  "restrictions": null,
  "required_linear_history": true,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "block_creations": false,
  "required_conversation_resolution": true,
  "lock_branch": false,
  "allow_fork_syncing": true
}
