{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "photonstrust.pdk_manifest.v0.schema.json",
  "title": "PhotonTrust PDK Manifest Artifact (v0.1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "generated_at",
    "execution_mode",
    "adapter",
    "request",
    "pdk",
    "capabilities"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "kind": { "type": "string", "const": "photonstrust.pdk_manifest" },
    "generated_at": { "type": "string", "format": "date-time" },
    "execution_mode": {
      "type": "string",
      "enum": ["preview", "certification"]
    },
    "source_run_id": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{8,64}$"
    },
    "adapter": { "type": "string", "minLength": 1 },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "manifest_path"],
      "properties": {
        "name": { "type": ["string", "null"] },
        "manifest_path": { "type": ["string", "null"] }
      },
      "oneOf": [
        {
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "manifest_path": { "type": "null" }
          }
        },
        {
          "properties": {
            "name": { "type": "null" },
            "manifest_path": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "pdk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "design_rules", "notes"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "design_rules": { "type": "object" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "layer_stack": {
          "type": "array",
          "items": { "type": "object" }
        },
        "component_cells": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supports_layout",
        "supports_performance_drc",
        "supports_lvs_lite_signoff",
        "supports_spice_export"
      ],
      "properties": {
        "supports_layout": { "type": "boolean" },
        "supports_performance_drc": { "type": "boolean" },
        "supports_lvs_lite_signoff": { "type": "boolean" },
        "supports_spice_export": { "type": "boolean" }
      }
    }
  }
}
