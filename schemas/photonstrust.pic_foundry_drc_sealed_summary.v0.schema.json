{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "photonstrust.pic_foundry_drc_sealed_summary.v0.schema.json",
  "title": "PhotonTrust PIC Foundry DRC Sealed Summary (v0.1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "run_id",
    "status",
    "execution_backend",
    "started_at",
    "finished_at",
    "check_counts",
    "failed_check_ids",
    "failed_check_names",
    "rule_results",
    "deck_fingerprint",
    "error_code"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "kind": { "type": "string", "const": "pic.foundry_drc_sealed_summary" },
    "run_id": { "type": "string", "pattern": "^[a-z0-9_]{8,64}$" },
    "status": { "type": "string", "enum": ["pass", "fail", "error"] },
    "execution_backend": { "type": "string", "enum": ["mock", "generic_cli", "local_rules", "local"] },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "check_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed", "errored"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "errored": { "type": "integer", "minimum": 0 }
      }
    },
    "failed_check_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "failed_check_names": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rule_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "DRC.WG.MIN_WIDTH",
        "DRC.WG.MIN_SPACING",
        "DRC.WG.MIN_BEND_RADIUS",
        "DRC.WG.MIN_ENCLOSURE"
      ],
      "properties": {
        "DRC.WG.MIN_WIDTH": { "$ref": "#/$defs/rule_result" },
        "DRC.WG.MIN_SPACING": { "$ref": "#/$defs/rule_result" },
        "DRC.WG.MIN_BEND_RADIUS": { "$ref": "#/$defs/rule_result" },
        "DRC.WG.MIN_ENCLOSURE": { "$ref": "#/$defs/rule_result" }
      }
    },
    "deck_fingerprint": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9_.:+\\-/]{1,256}$"
    },
    "error_code": { "type": ["string", "null"] }
  },
  "$defs": {
    "rule_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "required_um", "observed_um", "violation_count", "entity_refs"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail", "error"] },
        "required_um": { "type": ["number", "null"], "minimum": 0 },
        "observed_um": { "type": ["number", "null"] },
        "violation_count": { "type": "integer", "minimum": 0 },
        "entity_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
