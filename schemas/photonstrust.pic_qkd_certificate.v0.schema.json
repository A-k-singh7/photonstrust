{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonstrust.dev/schemas/photonstrust.pic_qkd_certificate.v0.schema.json",
  "title": "PhotonTrust PIC to QKD certificate schema v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "generated_at",
    "decision",
    "graph_id",
    "inputs",
    "hashes",
    "provenance",
    "steps",
    "artifacts",
    "signoff",
    "signoff_report",
    "drc_summary",
    "lvs_summary",
    "pex_summary",
    "foundry_approval_summary",
    "simulation_result",
    "qkd_scenario",
    "qkd_sweep",
    "target_distance_summary",
    "signature"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "kind": {
      "type": "string",
      "const": "photonstrust.pic_qkd_certificate"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "decision": {
      "type": "string",
      "enum": [
        "GO",
        "HOLD"
      ]
    },
    "graph_id": {
      "type": "string"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "graph_path",
        "pdk",
        "pdk_version",
        "protocol",
        "wavelength_nm",
        "target_distance_km",
        "distances_km",
        "dry_run",
        "output_dir",
        "signing_key"
      ],
      "properties": {
        "graph_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "pdk": {
          "type": "string",
          "minLength": 1
        },
        "pdk_version": {
          "type": "string",
          "minLength": 1
        },
        "protocol": {
          "type": "string",
          "minLength": 1
        },
        "wavelength_nm": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "target_distance_km": {
          "type": "number",
          "minimum": 0
        },
        "distances_km": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number",
            "minimum": 0
          }
        },
        "dry_run": {
          "type": "boolean"
        },
        "output_dir": {
          "type": [
            "string",
            "null"
          ]
        },
        "signing_key": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "graph_hash",
        "compiled_netlist_hash",
        "assembly_report_hash",
        "signoff_report_hash",
        "simulation_result_hash",
        "qkd_sweep_hash",
        "certificate_payload_hash"
      ],
      "properties": {
        "graph_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "compiled_netlist_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "assembly_report_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "signoff_report_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "simulation_result_hash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        },
        "qkd_sweep_hash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        },
        "certificate_payload_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "photonstrust_version",
        "python",
        "platform"
      ],
      "properties": {
        "photonstrust_version": {
          "type": "string"
        },
        "python": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "error",
              "skipped"
            ]
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certificate_path"
      ],
      "properties": {
        "certificate_path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "run_id",
        "reasons"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "GO",
            "HOLD"
          ]
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "signoff_report": {
      "type": "object"
    },
    "drc_summary": {
      "type": "object"
    },
    "lvs_summary": {
      "type": "object"
    },
    "pex_summary": {
      "type": "object"
    },
    "foundry_approval_summary": {
      "type": "object"
    },
    "simulation_result": {
      "type": [
        "object",
        "null"
      ]
    },
    "qkd_scenario": {
      "type": [
        "object",
        "null"
      ]
    },
    "qkd_sweep": {
      "type": [
        "object",
        "null"
      ]
    },
    "target_distance_summary": {
      "type": [
        "object",
        "null"
      ]
    },
    "signature": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_path",
        "signature_b64",
        "message_sha256"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "ed25519"
        },
        "key_path": {
          "type": "string",
          "minLength": 1
        },
        "signature_b64": {
          "type": "string",
          "minLength": 1
        },
        "message_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
