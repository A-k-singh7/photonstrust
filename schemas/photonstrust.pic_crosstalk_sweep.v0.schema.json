{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "photonstrust.pic_crosstalk_sweep.v0.schema.json",
  "title": "PhotonTrust PIC Crosstalk Sweep (v0)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "parallel_length_um",
    "lambda_ref_nm",
    "wavelengths_nm",
    "gaps_um",
    "xt_db"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0" },
    "kind": { "type": "string", "const": "pic_crosstalk_sweep" },
    "parallel_length_um": { "type": "number", "exclusiveMinimum": 0.0 },
    "lambda_ref_nm": { "type": "number", "exclusiveMinimum": 1.0 },
    "wavelengths_nm": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "number", "exclusiveMinimum": 1.0 }
    },
    "gaps_um": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "number", "minimum": 0.0 }
    },
    "xt_db": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "number" }
      }
    },
    "notes": { "type": ["string", "null"] },
    "provenance": { "type": ["object", "null"] }
  }
}
