{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "photonstrust.pic_signoff_ladder.v0.schema.json",
  "title": "PhotonTrust PIC Signoff Ladder (v0.1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "kind",
    "run_id",
    "inputs",
    "ladder",
    "final_decision",
    "evidence_chain_root",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "kind": { "type": "string", "const": "pic.signoff_ladder" },
    "run_id": { "type": "string", "pattern": "^[a-f0-9]{8,64}$" },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chip_assembly_run_id", "chip_assembly_hash", "policy_hash", "multi_stage_enabled"],
      "properties": {
        "chip_assembly_run_id": { "type": "string", "pattern": "^[a-f0-9]{8,64}$" },
        "chip_assembly_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "policy_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "multi_stage_enabled": { "type": "boolean", "const": true }
      }
    },
    "ladder": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        { "$ref": "#/$defs/chip_assembly_stage" },
        { "$ref": "#/$defs/drc_stage" },
        { "$ref": "#/$defs/lvs_stage" },
        { "$ref": "#/$defs/pex_stage" },
        { "$ref": "#/$defs/foundry_approval_stage" }
      ],
      "items": false
    },
    "final_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "reasons"],
      "properties": {
        "decision": { "type": "string", "enum": ["GO", "HOLD"] },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence_chain_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["photonstrust_version", "python", "platform"],
      "properties": {
        "photonstrust_version": { "type": "string" },
        "python": { "type": "string" },
        "platform": { "type": "string" }
      }
    }
  },
  "$defs": {
    "stage_base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "stage",
        "status",
        "run_id",
        "reason",
        "evidence_hashes",
        "failure_rule_ids",
        "waived_rule_ids",
        "prev_stage_hash",
        "stage_hash"
      ],
      "properties": {
        "level": { "type": "integer", "minimum": 1 },
        "stage": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "hold", "waived", "skipped", "error"]
        },
        "run_id": { "type": "string", "pattern": "^[a-f0-9]{8,64}$" },
        "reason": { "type": "string", "minLength": 1 },
        "evidence_hashes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "failure_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "waived_rule_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "prev_stage_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "stage_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "chip_assembly_stage": {
      "allOf": [
        { "$ref": "#/$defs/stage_base" },
        {
          "type": "object",
          "properties": {
            "level": { "const": 1 },
            "stage": { "const": "chip_assembly" }
          }
        }
      ]
    },
    "drc_stage": {
      "allOf": [
        { "$ref": "#/$defs/stage_base" },
        {
          "type": "object",
          "properties": {
            "level": { "const": 2 },
            "stage": { "const": "drc" }
          }
        }
      ]
    },
    "lvs_stage": {
      "allOf": [
        { "$ref": "#/$defs/stage_base" },
        {
          "type": "object",
          "properties": {
            "level": { "const": 3 },
            "stage": { "const": "lvs" }
          }
        }
      ]
    },
    "pex_stage": {
      "allOf": [
        { "$ref": "#/$defs/stage_base" },
        {
          "type": "object",
          "properties": {
            "level": { "const": 4 },
            "stage": { "const": "pex" }
          }
        }
      ]
    },
    "foundry_approval_stage": {
      "allOf": [
        { "$ref": "#/$defs/stage_base" },
        {
          "type": "object",
          "properties": {
            "level": { "const": 5 },
            "stage": { "const": "foundry_approval" }
          }
        }
      ]
    }
  }
}
