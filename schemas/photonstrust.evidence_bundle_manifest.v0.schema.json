{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "photonstrust.evidence_bundle_manifest.v0.schema.json",
  "title": "PhotonTrust Evidence Bundle Manifest (v0.1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "kind", "root_run_id", "include_children", "included_run_ids", "files", "missing"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "generated_at": { "type": "string" },
    "kind": { "type": "string", "const": "photonstrust.evidence_bundle" },
    "root_run_id": { "type": "string", "pattern": "^[a-f0-9]{8,64}$" },
    "include_children": { "type": "boolean" },
    "included_run_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-f0-9]{8,64}$" }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/file_record" }
    },
    "missing": {
      "type": "array",
      "items": { "$ref": "#/$defs/missing_record" }
    }
  },
  "$defs": {
    "file_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "missing_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "path", "error"],
      "properties": {
        "run_id": { "type": "string", "pattern": "^[a-f0-9]{8,64}$" },
        "path": { "type": ["string", "null"] },
        "error": { "type": "string" }
      }
    }
  }
}

