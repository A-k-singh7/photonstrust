{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photonstrust.dev/schemas/photonstrust.satellite_qkd_chain_certificate.v0.schema.json",
  "title": "PhotonTrust Satellite QKD Chain Certificate v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "run_id",
    "generated_at",
    "mission",
    "ground_station",
    "pass",
    "uncertainty_budget",
    "signoff"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "kind": {
      "type": "string",
      "const": "satellite_qkd_chain_certificate"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "mission": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "orbit_provider": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "provider_name",
            "provider_version",
            "source_hash",
            "trust_status"
          ],
          "properties": {
            "provider_name": {
              "type": "string",
              "minLength": 1
            },
            "provider_version": {
              "type": "string",
              "minLength": 1
            },
            "source_hash": {
              "type": "string",
              "minLength": 8
            },
            "trust_status": {
              "type": "string",
              "enum": ["trusted", "untrusted", "unavailable"]
            }
          }
        }
      }
    },
    "ground_station": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latitude_deg",
        "eta_chip",
        "eta_ground_terminal"
      ],
      "properties": {
        "latitude_deg": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "pic_cert_run_id": {
          "type": ["string", "null"]
        },
        "eta_chip": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "eta_ground_terminal": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "pass": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "altitude_km",
        "elevation_min_deg",
        "pass_duration_s",
        "samples_evaluated",
        "samples_with_positive_key_rate",
        "key_bits_accumulated",
        "mean_key_rate_bps",
        "peak_key_rate_bps",
        "peak_elevation_deg"
      ],
      "properties": {
        "altitude_km": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "elevation_min_deg": {
          "type": "number",
          "minimum": 0,
          "maximum": 90
        },
        "pass_duration_s": {
          "type": "number",
          "minimum": 0
        },
        "samples_evaluated": {
          "type": "integer",
          "minimum": 0
        },
        "samples_with_positive_key_rate": {
          "type": "integer",
          "minimum": 0
        },
        "key_bits_accumulated": {
          "type": "number",
          "minimum": 0
        },
        "mean_key_rate_bps": {
          "type": "number",
          "minimum": 0
        },
        "peak_key_rate_bps": {
          "type": "number",
          "minimum": 0
        },
        "peak_elevation_deg": {
          "type": "number",
          "minimum": 0,
          "maximum": 90
        }
      }
    },
    "annual_estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passes_per_day",
        "clear_sky_probability",
        "key_bits_per_year",
        "key_mbits_per_year"
      ],
      "properties": {
        "passes_per_day": {
          "type": "number",
          "minimum": 0
        },
        "clear_sky_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "key_bits_per_year": {
          "type": "number",
          "minimum": 0
        },
        "key_mbits_per_year": {
          "type": "number",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "uncertainty_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "rollup_method",
        "required_components",
        "missing_components",
        "components",
        "total_sigma_cps",
        "max_allowed_sigma_cps",
        "is_complete",
        "within_threshold",
        "pass"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "rollup_method": {
          "type": "string",
          "enum": ["rss"]
        },
        "required_components": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "missing_components": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "sigma_cps",
              "present",
              "source"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "sigma_cps": {
                "type": ["number", "null"],
                "minimum": 0
              },
              "present": {
                "type": "boolean"
              },
              "source": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "total_sigma_cps": {
          "type": "number",
          "minimum": 0
        },
        "max_allowed_sigma_cps": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "is_complete": {
          "type": "boolean"
        },
        "within_threshold": {
          "type": "boolean"
        },
        "pass": {
          "type": "boolean"
        }
      }
    },
    "signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "key_rate_positive_at_zenith",
        "annual_key_above_1mbit",
        "provider_trusted",
        "provider_parity_ok",
        "provider_uncertainty_ok",
        "uncertainty_budget_complete",
        "uncertainty_budget_within_threshold",
        "uncertainty_budget_ok",
        "orbit_provider_trust_status",
        "hold_reasons"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["GO", "HOLD"]
        },
        "key_rate_positive_at_zenith": {
          "type": "boolean"
        },
        "annual_key_above_1mbit": {
          "type": "boolean"
        },
        "provider_trusted": {
          "type": "boolean"
        },
        "provider_parity_ok": {
          "type": "boolean"
        },
        "provider_uncertainty_ok": {
          "type": "boolean"
        },
        "uncertainty_budget_complete": {
          "type": "boolean"
        },
        "uncertainty_budget_within_threshold": {
          "type": "boolean"
        },
        "uncertainty_budget_ok": {
          "type": "boolean"
        },
        "orbit_provider_trust_status": {
          "type": "string",
          "enum": ["trusted", "untrusted", "unavailable"]
        },
        "hold_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "signature": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "orbit_provider": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requested_name",
            "selected_name",
            "used_fallback"
          ],
          "properties": {
            "requested_name": {
              "type": "string"
            },
            "selected_name": {
              "type": "string"
            },
            "used_fallback": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "orbit_provider": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "provider_name",
            "provider_version",
            "source_hash",
            "trust_status"
          ],
          "properties": {
            "provider_name": {
              "type": "string",
              "minLength": 1
            },
            "provider_version": {
              "type": "string",
              "minLength": 1
            },
            "source_hash": {
              "type": "string",
              "minLength": 8
            },
            "trust_status": {
              "type": "string",
              "enum": ["trusted", "untrusted", "unavailable"]
            }
          }
        }
      }
    }
  }
}
