    {"name": "si_partial_etch", "gds_layer": 101, "gds_datatype": 0, "material": "Si", "thickness_um": 0.09},
    {"name": "box", "gds_layer": 200, "gds_datatype": 0, "material": "SiO2", "thickness_um": 2.0},
    {"name": "ge_pd", "gds_layer": 102, "gds_datatype": 0, "material": "Ge", "thickness_um": 0.50},
    {"name": "metal1", "gds_layer": 110, "gds_datatype": 0, "material": "Al", "thickness_um": 0.80},
    {"name": "metal2", "gds_layer": 111, "gds_datatype": 0, "material": "Al", "thickness_um": 2.00},
    {"name": "heater", "gds_layer": 103, "gds_datatype": 0, "material": "TiN", "thickness_um": 0.10}
  ],
  "component_cells": [
    {"name": "gc_te_c_band", "library": "imec_isipp50g", "cell": "GC_TE_1550", "ports": ["opt_in", "opt_out"], "maps_to_internal_kind": "pic.grating_coupler", "default_params": {"insertion_loss_db": 3.0}},
    {"name": "strip_waveguide", "library": "imec_isipp50g", "cell": "WG_STRIP", "ports": ["in", "out"], "maps_to_internal_kind": "pic.waveguide", "default_params": {"loss_db_per_cm": 1.5}},
    {"name": "rib_waveguide", "library": "imec_isipp50g", "cell": "WG_RIB", "ports": ["in", "out"], "maps_to_internal_kind": "pic.waveguide", "default_params": {"loss_db_per_cm": 0.5}},
    {"name": "mzm_pn_depletion", "library": "imec_isipp50g", "cell": "MZM_PN", "ports": ["in", "out"], "maps_to_internal_kind": "pic.mzm", "default_params": {"V_pi_L_pi_Vcm": 2.0, "insertion_loss_db": 4.0, "phase_shifter_length_mm": 3.0}},
    {"name": "ge_photodetector", "library": "imec_isipp50g", "cell": "GE_PD", "ports": ["in", "out"], "maps_to_internal_kind": "pic.photodetector", "default_params": {"alpha_per_cm": 5000.0, "length_um": 20.0}},
    {"name": "thermal_tuner", "library": "imec_isipp50g", "cell": "HEATER", "ports": ["in", "out"], "maps_to_internal_kind": "pic.heater", "default_params": {"length_um": 200.0, "material": "Si"}},
    {"name": "mmi_1x2", "library": "imec_isipp50g", "cell": "MMI_1X2", "ports": ["in", "out1", "out2"], "maps_to_internal_kind": "pic.mmi", "default_params": {"insertion_loss_db": 0.3, "n_ports_in": 1, "n_ports_out": 2}},
    {"name": "ring_filter", "library": "imec_isipp50g", "cell": "RING", "ports": ["in", "out"], "maps_to_internal_kind": "pic.ring", "default_params": {"insertion_loss_db": 0.5}}
  ],
  "interop": null
}
