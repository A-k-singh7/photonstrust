{
  "name": "aim_photonics_300nm_sin",
  "version": "0.1",
  "design_rules": {
    "min_waveguide_width_um": 0.50,
    "min_waveguide_gap_um": 0.25,
    "min_bend_radius_um": 10.0
  },
  "notes": [
    "Illustrative AIM 300 nm SiN corner-enabled manifest for corner-risk workflows."
  ],
  "capabilities": {
    "supports_layout": true,
    "supports_performance_drc": true,
    "supports_lvs_lite_signoff": true,
    "supports_spice_export": true
  },
  "process_corners": {
    "TT": {
      "waveguide_width_nm": 0.0,
      "propagation_loss_db_per_cm": 1.60,
      "coupler_gap_nm": 0.0,
      "ring_width_nm": 0.0
    },
    "SS": {
      "waveguide_width_nm": -6.0,
      "propagation_loss_db_per_cm": 1.95,
      "coupler_gap_nm": 5.0,
      "ring_width_nm": -6.0
    },
    "FF": {
      "waveguide_width_nm": 6.0,
      "propagation_loss_db_per_cm": 1.35,
      "coupler_gap_nm": -5.0,
      "ring_width_nm": 6.0
    },
    "FS": {
      "waveguide_width_nm": 5.0,
      "propagation_loss_db_per_cm": 1.85,
      "coupler_gap_nm": -4.0,
      "ring_width_nm": 5.0
    },
    "SF": {
      "waveguide_width_nm": -5.0,
      "propagation_loss_db_per_cm": 1.40,
      "coupler_gap_nm": 4.0,
      "ring_width_nm": -5.0
    }
  },
  "sensitivity_coefficients": {
    "coupling_ratio_per_gap_um": -1.9,
    "ring_resonance_nm_per_width_nm": -0.012,
    "waveguide_width_nm_to_key_rate_rel": 0.004,
    "propagation_loss_db_per_cm_to_key_rate_rel": -0.080
  },
  "component_cells": [
    {
      "name": "grating_coupler_te",
      "library": "aim",
      "cell": "GC_TE",
      "ports": ["opt1", "opt2"],
      "nominal_il_db": 2.4
    },
    {
      "name": "edge_coupler_te",
      "library": "aim",
      "cell": "EC_TE",
      "ports": ["opt1", "opt2"],
      "nominal_il_db": 0.9
    }
  ]
}
