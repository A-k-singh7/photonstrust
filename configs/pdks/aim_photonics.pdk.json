{
  "name": "aim_photonics",
  "version": "1.0",
  "design_rules": {
    "min_waveguide_width_um": 0.50,
    "min_waveguide_gap_um": 0.25,
    "min_bend_radius_um": 10.0
  },
  "notes": [
    "Runtime AIM Photonics manifest for alias-driven loading.",
    "Illustrative values only; replace with foundry-approved deck data in production."
  ],
  "capabilities": {
    "supports_layout": true,
    "supports_performance_drc": true,
    "supports_lvs_lite_signoff": true,
    "supports_spice_export": true
  },
  "layer_stack": [
    {
      "name": "si_core",
      "gds_layer": 1,
      "gds_datatype": 0,
      "material": "Si",
      "thickness_um": 0.22
    },
    {
      "name": "si_nitride",
      "gds_layer": 3,
      "gds_datatype": 0,
      "material": "SiN",
      "thickness_um": 0.40
    }
  ],
  "component_cells": [
    {
      "name": "grating_coupler_te",
      "library": "aim",
      "cell": "GC_TE",
      "ports": ["opt1", "opt2"],
      "nominal_il_db": 2.6,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.grating_coupler",
      "recommended_workflows": ["layout", "gds", "coupling_budget"]
    },
    {
      "name": "edge_coupler_te",
      "library": "aim",
      "cell": "EC_TE",
      "ports": ["opt1", "opt2"],
      "nominal_il_db": 1.0,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.edge_coupler",
      "recommended_workflows": ["layout", "gds", "coupling_budget"]
    },
    {
      "name": "waveguide_straight",
      "library": "aim",
      "cell": "WG_STRAIGHT",
      "ports": ["o1", "o2"],
      "nominal_loss_db_per_cm": 2.1,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.waveguide",
      "recommended_workflows": ["layout", "routing", "gds"]
    },
    {
      "name": "mmi_2x2",
      "library": "aim",
      "cell": "MMI_2X2",
      "ports": ["in1", "in2", "out1", "out2"],
      "nominal_excess_loss_db": 0.4,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.coupler",
      "recommended_workflows": ["layout", "gds", "splitter_combiner"]
    },
    {
      "name": "phase_shifter",
      "library": "aim",
      "cell": "PHASE_SHIFTER_THERMO",
      "ports": ["in", "out"],
      "drive_type": "thermal",
      "nominal_il_db": 0.25,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.phase_shifter",
      "recommended_workflows": ["layout", "optimize", "gds"]
    },
    {
      "name": "ring_resonator",
      "library": "aim",
      "cell": "RING_SINGLE_BUS",
      "ports": ["bus_in", "bus_out"],
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.ring",
      "recommended_workflows": ["layout", "resonator_analysis"]
    },
    {
      "name": "waveguide_bend_euler",
      "library": "aim",
      "cell": "WG_BEND_EULER",
      "ports": ["o1", "o2"],
      "support_level": "layout_only",
      "recommended_workflows": ["layout", "routing", "gds"]
    },
    {
      "name": "spot_size_converter",
      "library": "aim",
      "cell": "SSC_EDGE",
      "ports": ["opt1", "opt2"],
      "support_level": "layout_only",
      "recommended_workflows": ["layout", "io_planning", "gds"]
    },
    {
      "name": "mzm_pn",
      "library": "aim",
      "cell": "MZM_PN_DEPLETION",
      "ports": ["in", "out"],
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.mzm",
      "default_params": {"V_pi_L_pi_Vcm": 2.5, "insertion_loss_db": 4.5, "phase_shifter_length_mm": 3.0},
      "recommended_workflows": ["layout", "gds", "modulator_analysis"]
    },
    {
      "name": "ge_pd",
      "library": "aim",
      "cell": "GE_PD",
      "ports": ["in", "out"],
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.photodetector",
      "default_params": {"alpha_per_cm": 4500.0, "length_um": 25.0},
      "recommended_workflows": ["layout", "gds", "detector_analysis"]
    },
    {
      "name": "thermal_tuner",
      "library": "aim",
      "cell": "HEATER_TIN",
      "ports": ["in", "out"],
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.heater",
      "default_params": {"length_um": 300.0, "material": "Si"},
      "recommended_workflows": ["layout", "gds", "phase_tuning"]
    },
    {
      "name": "awg_8ch",
      "library": "aim",
      "cell": "AWG_8CH_CWDM",
      "ports": ["in", "out1", "out2", "out3", "out4", "out5", "out6", "out7", "out8"],
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.awg",
      "default_params": {"n_channels": 8, "channel_spacing_nm": 20.0, "insertion_loss_db": 3.0},
      "recommended_workflows": ["layout", "gds", "wavelength_routing"]
    }
  ],
  "interop": {
    "aim": {
      "enabled": true,
      "technology_name": "AIM",
      "pdk_release": "v3"
    },
    "siepic": {
      "enabled": true,
      "technology_name": "AIM_for_SiEPIC"
    }
  }
}
