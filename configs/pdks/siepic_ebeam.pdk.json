{
  "name": "siepic_ebeam",
  "version": "0.1",
  "design_rules": {
    "min_waveguide_width_um": 0.50,
    "min_waveguide_gap_um": 0.20,
    "min_bend_radius_um": 5.0
  },
  "notes": [
    "Illustrative SiEPIC EBeam-style manifest for public-facing adapter coverage.",
    "Metadata is redistribution-safe and should be replaced with foundry-approved rule decks where required."
  ],
  "capabilities": {
    "supports_layout": true,
    "supports_performance_drc": true,
    "supports_lvs_lite_signoff": true,
    "supports_spice_export": true
  },
  "layer_stack": [
    {
      "name": "si_core",
      "gds_layer": 1,
      "gds_datatype": 0,
      "material": "Si",
      "thickness_um": 0.22
    },
    {
      "name": "heater_metal",
      "gds_layer": 31,
      "gds_datatype": 0,
      "material": "Metal",
      "thickness_um": 0.15
    }
  ],
  "component_cells": [
    {
      "name": "grating_coupler_te",
      "library": "siepic_ebeam",
      "cell": "GC_TE_1550",
      "ports": ["opt1", "opt2"],
      "nominal_il_db": 2.9,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.grating_coupler",
      "recommended_workflows": ["layout", "gds", "coupling_budget"]
    },
    {
      "name": "edge_coupler_te",
      "library": "siepic_ebeam",
      "cell": "EC_TE",
      "ports": ["opt1", "opt2"],
      "nominal_il_db": 1.1,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.edge_coupler",
      "recommended_workflows": ["layout", "gds", "coupling_budget"]
    },
    {
      "name": "waveguide_straight",
      "library": "siepic_ebeam",
      "cell": "WG_STRAIGHT",
      "ports": ["o1", "o2"],
      "nominal_loss_db_per_cm": 2.0,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.waveguide",
      "recommended_workflows": ["layout", "routing", "gds"]
    },
    {
      "name": "mmi_2x2",
      "library": "siepic_ebeam",
      "cell": "MMI_2X2",
      "ports": ["in1", "in2", "out1", "out2"],
      "nominal_excess_loss_db": 0.35,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.coupler",
      "recommended_workflows": ["layout", "gds", "splitter_combiner"]
    },
    {
      "name": "phase_shifter",
      "library": "siepic_ebeam",
      "cell": "PS_HEATER",
      "ports": ["in", "out"],
      "drive_type": "thermal",
      "nominal_il_db": 0.22,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.phase_shifter",
      "recommended_workflows": ["layout", "optimize", "gds"]
    },
    {
      "name": "ring_resonator",
      "library": "siepic_ebeam",
      "cell": "RING_SINGLE_BUS",
      "ports": ["bus_in", "bus_out"],
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.ring",
      "recommended_workflows": ["layout", "resonator_analysis"]
    },
    {
      "name": "waveguide_bend_euler",
      "library": "siepic_ebeam",
      "cell": "WG_BEND_EULER",
      "ports": ["o1", "o2"],
      "support_level": "layout_only",
      "recommended_workflows": ["layout", "routing", "gds"]
    },
    {
      "name": "monitor_tap_1x2",
      "library": "siepic_ebeam",
      "cell": "MONITOR_TAP_1X2",
      "ports": ["in", "through", "tap"],
      "support_level": "layout_only",
      "recommended_workflows": ["layout", "monitoring", "gds"]
    },
    {
      "name": "photodiode_ge",
      "library": "siepic_ebeam",
      "cell": "PD_GE",
      "ports": ["opt_in"],
      "support_level": "characterized_external",
      "recommended_workflows": ["layout", "packaging", "touchstone_bridge"]
    },
    {
      "name": "awg_mux_demux",
      "library": "siepic_ebeam",
      "cell": "AWG_8CH",
      "ports": ["common", "ch1", "ch2", "ch3", "ch4", "ch5", "ch6", "ch7", "ch8"],
      "support_level": "layout_only",
      "recommended_workflows": ["layout", "packaging", "wavelength_routing"]
    },
    {
      "name": "mmi_1x2_te",
      "library": "siepic_ebeam",
      "cell": "MMI_1X2_TE",
      "ports": ["in", "out1", "out2"],
      "nominal_excess_loss_db": 0.25,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.mmi",
      "default_params": {"insertion_loss_db": 0.25, "n_ports_in": 1, "n_ports_out": 2},
      "recommended_workflows": ["layout", "gds", "splitter_combiner"]
    },
    {
      "name": "mmi_2x2_te",
      "library": "siepic_ebeam",
      "cell": "MMI_2X2_TE",
      "ports": ["in1", "in2", "out1", "out2"],
      "nominal_excess_loss_db": 0.30,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.mmi",
      "default_params": {"insertion_loss_db": 0.30, "n_ports_in": 2, "n_ports_out": 2},
      "recommended_workflows": ["layout", "gds", "splitter_combiner"]
    },
    {
      "name": "y_branch_te",
      "library": "siepic_ebeam",
      "cell": "Y_BRANCH_TE",
      "ports": ["in", "out1", "out2"],
      "nominal_excess_loss_db": 0.20,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.y_branch",
      "default_params": {"insertion_loss_db": 0.20},
      "recommended_workflows": ["layout", "gds", "splitter_combiner"]
    },
    {
      "name": "waveguide_crossing",
      "library": "siepic_ebeam",
      "cell": "WG_CROSSING",
      "ports": ["in1", "in2", "out1", "out2"],
      "nominal_excess_loss_db": 0.10,
      "support_level": "modeled",
      "maps_to_internal_kind": "pic.crossing",
      "default_params": {"insertion_loss_db": 0.10, "crosstalk_db": -40.0},
      "recommended_workflows": ["layout", "gds", "routing"]
    }
  ],
  "interop": {
    "siepic": {
      "enabled": true,
      "technology_name": "EBeam"
    }
  }
}
